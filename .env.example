# WashApp — ortam degiskenleri sablonu. Kopyala: cp .env.example .env
# KURAL: gercek sirlar .env'de tutulur ve repoya ASLA commit'lenmez (.gitignore).

# --- Mobil (EXPO_PUBLIC_* — istemcide gomulur, SIR ICERMEZ) ------------------
EXPO_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Backend (FastAPI @ Render — SIR; yalnizca server tarafinda) -------------
# Supavisor transaction pooler: port 6543 ZORUNLU, statement_cache_size=0
DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<pwd>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_JWKS_URL=https://<ref>.supabase.co/auth/v1/.well-known/jwks.json

# --- PSP (Iyzico Pazaryeri / alt-uye isyeri — escrow) ------------------------
IYZICO_API_KEY=<iyzico-api-key>
IYZICO_SECRET=<iyzico-secret>
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
PAYTR_MERCHANT_ID=<paytr-merchant-id>
PAYTR_MERCHANT_KEY=<paytr-merchant-key>

# --- Izleme ------------------------------------------------------------------
SENTRY_DSN=
