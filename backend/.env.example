# WashApp Backend — Ortam Degiskenleri (ornek)
# Render env var olarak set edilir; repoda GERCEK deger ASLA bulunmaz.

# --- Ortam ---
APP_ENV=dev                       # dev | staging | prod
LOG_LEVEL=INFO
SENTRY_DSN=

# --- Supabase ---
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>          # GIZLI — money/audit semasi erisimi
SUPABASE_JWT_ISSUER=https://<ref>.supabase.co/auth/v1
# JWKS: Supabase Auth public anahtarlari (RS256 JWT dogrulama)
SUPABASE_JWKS_URL=https://<ref>.supabase.co/auth/v1/.well-known/jwks.json

# --- Postgres: Supavisor TRANSACTION pooler (port 6543 ZORUNLU) ---
# statement_cache_size=0 (db.py icinde kod ile zorlanir; pgbouncer/transaction-mode uyumu)
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# --- Iyzico Pazaryeri (escrow; para WashApp'a ASLA girmez, alt-uye isyeri payout) ---
IYZICO_API_KEY=<iyzico-api-key>
IYZICO_SECRET_KEY=<iyzico-secret-key>                 # HMAC webhook dogrulama + imza
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com       # prod: https://api.iyzipay.com
IYZICO_WEBHOOK_SECRET=<webhook-hmac-secret>           # X-IYZ-SIGNATURE dogrulama

# --- CORS (virgulle ayrilmis origin'ler; native app icin bos birakilabilir) ---
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# --- Fiyat sabitleri (plan ile celismez — orders'a islem aninda kopyalanir) ---
COMMISSION_RATE=0.22              # platform komisyon orani
KORUMA_FONU_TL=15.00             # islem basi koruma fonu katkisi
SUBSCRIPTION_2_WASH_TL=790.00    # 2 yikama/ay
SUBSCRIPTION_4_WASH_TL=1490.00   # 4 yikama/ay
AOV_TL=450.00                    # ortalama sepet (GMV varsayilan)

# --- Is kurallari ---
CONFIRM_WINDOW_HOURS=24          # musteri onay penceresi (24s otomatik onay)
EVIDENCE_SIGNED_URL_TTL=60       # saniye (foto/KYC goruntuleme)
PROVIDER_MIN_RATING=4.2          # aktiflik esigi
GEOFENCE_RADIUS_M=3000           # dispatch KNN yaricapi
