{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "WashApp base tsconfig",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": false,
    "baseUrl": ".",
    "paths": {
      "@washapp/config": ["packages/config/index.ts"],
      "@washapp/types": ["packages/types/index.ts"],
      "@washapp/api-client": ["packages/api-client/index.ts"],
      "@washapp/supabase": ["packages/supabase/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", ".expo", "android", "ios"]
}
